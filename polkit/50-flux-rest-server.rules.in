// Allow the web-server user to start (only) per-user flux-rest-server socket
// units, so the front end can bring a user's service up on demand. The account
// is set at build time via "configure --with-web-user" (default www-data).
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "@WEB_USER@" &&
        action.lookup("unit").indexOf("flux-rest-server@") == 0) {
        return polkit.Result.YES;
    }
});
